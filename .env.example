# Anthropic API Key (required for LLM extraction)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# API Base URL (optional, for proxy endpoints like minimax)
# If using official Anthropic API, leave empty or comment out
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# GitHub Personal Access Token (required for PR creation)
# Needs repo scope
# Generate at: https://github.com/settings/tokens/new
# Scopes: repo (Full control of private repositories)
GITHUB_TOKEN=ghp_...

# Target repository for PR creation
GITHUB_REPO_OWNER=AcWiz
GITHUB_REPO_NAME=awesome-ocean-da
